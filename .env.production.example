ENVIRONMENT=production
NODE_ENV=production

# Global auth and internal access
NEXTAUTH_SECRET=
JWT_SECRET=
INTERNAL_API_KEY=
POSEIDON_API_KEY=

# Canonical service endpoints (no localhost in production)
POSEIDON_API_URL=
CORE_API_URL=
INTAKE_API_URL=
AVAILITY_SERVICE_URL=

# Database and cache
DATABASE_URL=
REDIS_URL=

# If URLs above are not provided, these become required:
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# Storage
MINIO_SECRET_KEY=
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_BUCKET=
MINIO_SECURE=true

# Ingestion and public inquiry
PUBLIC_INQUIRY_TO=
GMAIL_INTAKE_USER=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
PUBLIC_INQUIRY_ALLOWED_ORIGINS=

# Integrations
AVAILITY_BASE_URL=
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=
AVAILITY_TOKEN_URL=
STEDI_API_KEY=
