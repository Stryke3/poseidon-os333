<svg viewBox="0 0 400 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#05080f;stop-opacity:1" />
      <stop offset="55%" style="stop-color:#080f15;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0d1117;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="glowGrad">
      <stop offset="0%" style="stop-color:#f0b432;stop-opacity:0.18" />
      <stop offset="100%" style="stop-color:#f0b432;stop-opacity:0" />
    </radialGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="600" fill="url(#bgGrad)" />
  
  <!-- Glow effects -->
  <circle cx="200" cy="300" r="150" fill="url(#glowGrad)" opacity="0.3" />
  <circle cx="150" cy="200" r="80" fill="url(#glowGrad)" opacity="0.2" />
  <circle cx="300" cy="400" r="100" fill="url(#glowGrad)" opacity="0.25" />
  
  <!-- Medical/Healthcare elements -->
  <rect x="50" y="450" width="300" height="120" fill="rgba(240,180,106,0.1)" rx="8" />
  <text x="200" y="510" text-anchor="middle" fill="#f0b432" font-family="Arial, sans-serif" font-size="14" font-weight="600">NORTHSTAR SURGICAL INSTITUTE</text>
  
  <!-- Abstract healthcare patterns -->
  <path d="M 100 150 Q 200 100 300 150" stroke="rgba(6,182,212,0.3)" stroke-width="2" fill="none" />
  <path d="M 300 300 Q 250 350 200 400" stroke="rgba(6,182,212,0.2)" stroke-width="1" fill="none" />
  <circle cx="100" cy="450" r="3" fill="#06b6d4" />
  <circle cx="300" cy="450" r="3" fill="#8b5cf6" />
  <circle cx="200" cy="150" r="2" fill="#14b8a6" />
</svg>
