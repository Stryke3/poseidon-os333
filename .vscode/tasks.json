{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open Codex (CLI)",
      "type": "shell",
      "command": "/bin/bash",
      "args": ["${workspaceFolder}/scripts/launch-codex.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "new"
      }
    },
    {
      "label": "Open Claude (CLI)",
      "type": "shell",
      "command": "/bin/bash",
      "args": ["${workspaceFolder}/scripts/launch-claude.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "new"
      }
    },
    {
      "label": "Open Codex (Terminal.app)",
      "type": "shell",
      "command": "open",
      "args": [
        "-a",
        "Terminal",
        "${workspaceFolder}/scripts/Launch-Codex-CLI.command"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Open Claude (Terminal.app)",
      "type": "shell",
      "command": "open",
      "args": [
        "-a",
        "Terminal",
        "${workspaceFolder}/scripts/Launch-Claude-CLI.command"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
