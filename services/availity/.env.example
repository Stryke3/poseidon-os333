# Availity Integration Service
# Copy to .env and fill in AVAILITY_CLIENT_ID / AVAILITY_CLIENT_SECRET (required for live calls).

# ── Server ──
PORT=8005
NODE_ENV=development

# ── Database (shared Poseidon DB or dedicated) ──
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_MANAGED_POSTGRES_HOST:5432/DATABASE_NAME?schema=public

# ── Availity OAuth2 (test / sandbox) ──
AVAILITY_BASE_URL=https://tst.api.availity.com
AVAILITY_TOKEN_URL=https://tst.api.availity.com/v1/token
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=
AVAILITY_SCOPE=scope_one scope_two

# ── Availity API paths (relative to AVAILITY_BASE_URL) ──
AVAILITY_ELIGIBILITY_PATH=/v1/coverages/eligibility
AVAILITY_PRIOR_AUTH_PATH=/v1/authorizations

# ── HTTP client ──
AVAILITY_TIMEOUT_MS=30000
