# Domain
DOMAIN=strykefox.com
CORS_ALLOW_ORIGINS=https://dashboard.strykefox.com,http://localhost,http://127.0.0.1
TRUSTED_HOSTS=dashboard.strykefox.com,app.strykefox.com,api.strykefox.com,trident.strykefox.com,intake.strykefox.com,ml.strykefox.com,edi.strykefox.com,localhost,127.0.0.1,core,trident,intake,ml,edi,poseidon_core,poseidon_trident,poseidon_intake,poseidon_ml,poseidon_edi
EXPOSE_API_DOCS=false
