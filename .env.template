# Public inquiries
PUBLIC_INQUIRY_TO=patients@strykefox.com
GMAIL_INTAKE_USER=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# Service tuning
ENVIRONMENT=production
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DENIAL_THRESHOLD=0.65
WRITE_OFF_DOLLAR_THRESHOLD=50.00
# Fax inbound: below this (0–1) OCR confidence → intake_incomplete, no auto patient/order from OCR
INTAKE_OCR_CONFIDENCE_THRESHOLD=0.55
# 837 claim: require orders.billing_ready_at; block duplicate successful claim_submissions per order (set false only for break-glass / tests)
BILLING_CLAIM_REQUIRE_BILLING_READY=true
BILLING_CLAIM_BLOCK_DUPLICATE_SUBMISSION=true
APPEAL_WINDOW_DAYS=60
MIN_TRAINING_RECORDS=25
TRIDENT_LEARNING_MODE=continuous
TRIDENT_LEARNING_INTERVAL_MINUTES=15
TRIDENT_LEARNING_LOOKBACK_DAYS=365
TRIDENT_LEARNING_AUTO_RETRAIN=true
LOG_LEVEL=INFO
PHI_IN_LOGS=false
