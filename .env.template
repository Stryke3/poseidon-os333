# Infrastructure (local Docker: match docker-compose defaults — user poseidon, password poseidon, Redis localredis)
POSTGRES_USER=poseidon
POSTGRES_PASSWORD=poseidon
POSTGRES_DB=poseidon_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host-only (psql, backup_postgres.sh, migrations from your machine): loopback to published :5432.
DATABASE_URL=postgresql://poseidon:poseidon@127.0.0.1:5432/poseidon_db
#
# **Docker Compose app services** (Core, Trident, Intake, ML, EDI, Availity) take the DB URL from
# docker-compose.yml → POSEIDON_DATABASE_URL, NOT from DATABASE_URL above. Leave POSEIDON_DATABASE_URL
# unset to use the bundled `postgres` container. For managed Postgres, set:
#   POSEIDON_DATABASE_URL=postgresql://user:pass@host.example/db?sslmode=require
# The container entrypoint also respects DATABASE_URL when set by the platform (e.g. some hosts inject it).
# POSEIDON_DATABASE_URL=
REDIS_PASSWORD=localredis
REDIS_URL=redis://:localredis@redis:6379/0

# Auth
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
SECRET_KEY=CHANGE_ME_64_CHAR_HEX
POSEIDON_API_KEY=CHANGE_ME_64_CHAR_HEX
INTERNAL_API_KEY=poseidon-local-internal-key
# CLI / batch ingest: scripts/ingest_lvco.sh (Core POST /orders/import)
POSEIDON_INGEST_EMAIL=
POSEIDON_INGEST_PASSWORD=
# Optional: skip login and use a JWT from /auth/login
# POSEIDON_ACCESS_TOKEN=
# Batch ingest (scripts/ingest_lvco.py): must hit Core /auth/login — NOT Next.js /api/auth (NextAuth).
# - Direct Core: http://127.0.0.1:8001
# - Dashboard BFF (nginx → Next → Core): http://localhost/api/core
CORE_BASE_URL=http://127.0.0.1:8001
# WHT data-room automation (scripts/wht_data_room_pull.py)
# WHT_DATA_ROOM_DIR=/absolute/path/to/wht/workspace/data-room
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8
NEXTAUTH_SECRET=CHANGE_ME_64_CHAR_HEX
NEXTAUTH_URL=http://localhost
# NextAuth behind nginx/Docker: must be true so cookies/session use X-Forwarded-Host (see docker-compose dashboard).
AUTH_TRUST_HOST=true
ALLOW_CORE_SERVICE_ACCOUNT_FALLBACK=false

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=minio:9000
# Comma-separated hostnames allowed for Next.js document download proxy (presigned URL hosts). Example: minio.example.com,127.0.0.1
ALLOWED_STORAGE_DOWNLOAD_HOSTS=
MINIO_ACCESS_KEY=poseidon
MINIO_SECRET_KEY=poseidonlocal
MINIO_BUCKET=poseidon-docs
# If set and MINIO_BUCKET is empty, Core uses this bucket for order documents (alias for MINIO_BUCKET).
# MINIO_BUCKET_DOCUMENTS=
MINIO_SECURE=false

# Internal URLs
# Dashboard in Docker: http://core:8001. Local `npm run dev` in frontend/: use http://127.0.0.1:8001 in frontend/.env.local (Core is published on loopback in docker-compose.yml).
CORE_API_URL=http://core:8001
# Optional: set true on internet-facing dashboard builds to forbid localhost/127.0.0.1 in POSEIDON_API_URL (server-side).
# POSEIDON_ENFORCE_NO_LOCALHOST=false
TRIDENT_API_URL=http://trident:8002
# Dashboard /api/trident — LLM digest (live when a key is set; docker-compose passes these through)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TRIDENT_DIGEST_OPENAI_MODEL=gpt-4o-mini
TRIDENT_DIGEST_ANTHROPIC_MODEL=claude-3-5-haiku-20241022
TRIDENT_DIGEST_PROVIDER=auto
# TRIDENT_DIGEST_LLM=false
INTAKE_API_URL=http://intake:8003
# Optional comma-separated Intake base URLs used only when INTAKE_API_URL is unset (PDF live ingest fallbacks).
# INTAKE_API_FALLBACK_URLS=
ML_API_URL=http://ml:8004

# Matia pipeline merge into dashboard (optional). If MATIA_API_URL is unset and MATIA_INTEGRATION_ENABLED is not true, Core orders only.
#
# Docker Compose: nginx proxies /matia-api/* → host:8010 (see nginx.conf). Enable merge with:
#   MATIA_API_URL=http://nginx/matia-api
#   MATIA_INTEGRATION_ENABLED=true
# Matia must listen on host port 8010, or change proxy_pass in nginx.conf to your port.
# Host-only dev (dashboard not in Docker): MATIA_API_URL=http://127.0.0.1:8010
# Remote: MATIA_API_URL=https://matia.strykefox.com
# MATIA_PIPELINE_PATH=/pipeline
# MATIA_API_BEARER=
# MATIA_INTEGRATION_ENABLED=false

# Availity (Core Python: full URLs / EDI; Node availity service: BASE + PATH vars below)
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=
AVAILITY_BASE_URL=https://api.availity.com
AVAILITY_TOKEN_URL=https://api.availity.com/v1/token
AVAILITY_SCOPE=scope_one scope_two
AVAILITY_ELIGIBILITY_PATH=/v1/coverages/eligibility
AVAILITY_PRIOR_AUTH_PATH=/v1/authorizations
AVAILITY_TIMEOUT_MS=30000
# Core 270/837 endpoints (full URL or path per services/core — often same host as BASE)
AVAILITY_ELIGIBILITY_URL=https://api.availity.com/v1/coverages/eligibility
AVAILITY_CLAIMS_URL=
AVAILITY_CLAIM_STATUS_URL=
AVAILITY_SENDER_ID=POSEIDON
AVAILITY_RECEIVER_ID=AVAILITY
AVAILITY_DEFAULT_PROVIDER_NPI=
AVAILITY_BILLING_TIN=

# Browser → Availity Node service (Docker/nginx: path proxy on dashboard host; Vercel: full URL to your gateway)
NEXT_PUBLIC_AVAILITY_SERVICE_URL=/availity-api
# Dashboard server → Availity container (Next.js API proxy /api/integrations/availity/*)
AVAILITY_SERVICE_URL=http://availity:8005
# Optional: payer manual root for governance ingestion (default: services/trident/manuals relative to availity service)
TRIDENT_MANUALS_PATH=

# EDI Service (837P outbound / 835 inbound)
EDI_API_URL=http://edi:8006
EDI_DRY_RUN=true
# Dev only: skip Core claim_strategy check when Core is down (never enable in production)
# EDI_SKIP_CLAIM_AUTHORITY_CHECK=true
SUBMISSION_METHOD=stedi_api
# Raw key only (no "Bearer" prefix). Stedi docs: Authorization header = key value directly.
STEDI_API_KEY=key_your_stedi_api_key_here

# Availity SFTP (required when SUBMISSION_METHOD=availity_sftp)
AVAILITY_SFTP_HOST=files.availity.com
AVAILITY_SFTP_PORT=22
AVAILITY_SFTP_USER=Poseidon
AVAILITY_SFTP_PASS=CHANGE_ME
AVAILITY_USE_QA=false
AVAILITY_CUSTOMER_ID=2618273

# ISA Envelope (from Availity EDI Companion Guide)
ISA_SENDER_QUAL=ZZ
ISA_SENDER_ID=AV09311993
ISA_RECEIVER_QUAL=01
ISA_RECEIVER_ID=030240928
ISA_TEST_INDICATOR=T

